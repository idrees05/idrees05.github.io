DATABASE_URL=sqlite:///./kb.db
SECRET_KEY=change-this-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Azure Blob Storage (leave blank to use local disk fallback in dev)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=kb-files

# Power Automate webhook for SharePoint sync (leave blank to disable)
# Paste the HTTP trigger URL from your Power Automate flow here
POWER_AUTOMATE_WEBHOOK_URL=

# File upload limit in MB
UPLOAD_MAX_MB=20
